# Required (repo root for Python / `cargo run -p digitakt-cli -- serve` from checkout)
ANTHROPIC_API_KEY=sk-ant-...

# Tauri desktop app also reads:
#   ~/Library/Application Support/com.digitakt.llm/.env
# (same key; created automatically when you copy from this file)

# Optional — defaults shown
PORT=8000
DIGITAKT_URL=http://localhost:8000
DIGITAKT_LOG_FILE=          # set a path to enable JSON-lines structured logging
DIGITAKT_TRACE_FILE=        # set a path to enable JSON-lines LLM trace output
